@page
@model RegisterModel

@{
    ViewData["Title"] = "Registro";
}

<div class="d-flex justify-content-center align-items-center" style="min-height: 80vh;">
    <div class="card p-4" style="width: 100%; max-width: 500px;">

        <h2 class="text-center mb-4">
            <i class="fa-solid fa-user-plus"></i> Registro
        </h2>

        <form method="post">

            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Email" class="form-control" />
                <label asp-for="Input.Email">Correo electrónico</label>
                <span asp-validation-for="Input.Email" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Password" class="form-control" />
                <label asp-for="Input.Password">Contraseña</label>
                <span asp-validation-for="Input.Password" class="text-danger"></span>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.ConfirmPassword" class="form-control" />
                <label asp-for="Input.ConfirmPassword">Confirmar contraseña</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.NombreCompleto" class="form-control" />
                <label asp-for="Input.NombreCompleto">Nombre completo</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Telefono" class="form-control" />
                <label asp-for="Input.Telefono">Teléfono</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.Direccion" class="form-control" />
                <label asp-for="Input.Direccion">Dirección</label>
            </div>

            <div class="form-floating mb-3">
                <input asp-for="Input.IdiomaPreferido" class="form-control" />
                <label asp-for="Input.IdiomaPreferido">Idioma preferido</label>
            </div>

            <button type="submit" class="btn btn-primary w-100">
                Crear cuenta
            </button>

        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}