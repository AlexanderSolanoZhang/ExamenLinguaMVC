<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ExamenLinguaMVC</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />

    <style>
            body {
                font-family: 'Poppins', sans-serif;
                background-color: #f5f7fa;
            }

            /* Navbar */
            .navbar {
                background: linear-gradient(90deg, #1e3c72, #2a5298);
            }

            .navbar-brand {
                color: #fff !important;
                font-weight: 600;
            }

            .nav-link {
                color: #ddd !important;
                transition: 0.3s;
            }

            .nav-link:hover {
                color: #fff !important;
            }

            /* Card style */
            .card {
                border-radius: 12px;
                box-shadow: 0 4px 15px rgba(0,0,0,0.08);
                border: none;
            }

            /* Footer */
            footer {
                background-color: #1e3c72;
                color: #fff;
            }

            footer a {
                color: #ddd;
                text-decoration: none;
            }

            footer a:hover {
                color: #fff;
            }
    </style>
</head>

<body>
   

            <header>
                <nav class="navbar navbar-expand-lg shadow-sm">
                    <div class="container">

                        <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                            <i class="fa-solid fa-language"></i> LinguaMVC
                        </a>

                        <button class="navbar-toggler bg-light" type="button" data-bs-toggle="collapse" data-bs-target="#navbarMain">
                            <span class="navbar-toggler-icon"></span>
                        </button>

                        <div class="collapse navbar-collapse" id="navbarMain">
                            <ul class="navbar-nav ms-auto">

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Home" asp-action="Index">
                                        <i class="fa fa-home"></i> Home
                                    </a>
                                </li>
                                 @if (User.IsInRole("Administrador"))
                            {
                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Cursos" asp-action="Index">
                                        <i class="fa fa-book"></i> Cursos
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Horarios" asp-action="Index">
                                        <i class="fa fa-clock"></i> Horarios
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Instructores" asp-action="Index">
                                        <i class="fa fa-chalkboard-teacher"></i> Instructores
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="MaterialesDidacticos" asp-action="Index">
                                        <i class="fa fa-folder-open"></i> Materiales
                                    </a>
                                </li>

                                <li class="nav-item">
                                    <a class="nav-link" asp-controller="Niveles" asp-action="Index">
                                        <i class="fa fa-layer-group"></i> Niveles
                                    </a>
                                </li>
                                
                            }
                            <div class="ms-3">
                                <partial name="_LoginPartial" />
                            </div>
                        </div>
                    </div>
                </nav>
            </header>
        

    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="mt-5 pt-4 pb-3">
        <div class="container text-center">

            <p class="mb-1">
                <i class="fa fa-graduation-cap"></i> Plataforma de aprendizaje de idiomas
            </p>

            <p class="mb-1">
                &copy; - ExamenLinguaMVC
            </p>

     

        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
            
            document.addEventListener("scroll", function () {
                const navbar = document.querySelector(".navbar");
                if (window.scrollY > 50) {
                    navbar.classList.add("shadow");
                } else {
                    navbar.classList.remove("shadow");
                }
            });
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>