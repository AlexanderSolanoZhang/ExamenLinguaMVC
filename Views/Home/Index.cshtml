@{
    ViewData["Title"] = "Inicio";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="~/css/home.css" />

<div class="hero-white d-flex align-items-center">
    <div class="container text-center">

        <div class="badge-soft mb-3">
            Sistema Académico Profesional
        </div>

        <h1 class="display-4 fw-bold">
            Lingua MVC
        </h1>

        <p class="lead mt-3 text-muted">
            Plataforma profesional para la gestión, evaluación y administración de exámenes académicos.
        </p>

        <p class="small mt-3 text-secondary">
            Un sistema moderno, rápido y escalable diseñado para instituciones educativas que buscan digitalizar sus procesos.
        </p>

    </div>
</div>

<section class="features py-5">
    <div class="container">
        <div class="row text-center">

            <div class="col-md-4 mb-4">
                <div class="card feature-card shadow-sm">
                    <div class="card-body">
                        <h5>Gestión de Exámenes</h5>
                        <p>Administra evaluaciones de forma centralizada y eficiente.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card feature-card shadow-sm">
                    <div class="card-body">
                        <h5>Evaluación Automática</h5>
                        <p>Reduce tiempos con corrección estructurada y precisa.</p>
                    </div>
                </div>
            </div>

            <div class="col-md-4 mb-4">
                <div class="card feature-card shadow-sm">
                    <div class="card-body">
                        <h5>Panel Administrativo</h5>
                        <p>Control total del sistema desde un dashboard intuitivo.</p>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<script src="~/js/home.js"></script>