@{
    ViewData["Title"] = "Lingua System";
}

<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

<style>
    body {
        background: #f8fafc;
        font-family: system-ui, -apple-system, Segoe UI, Roboto, Arial, sans-serif;
        color: #0f172a;
    }

    /* TOP BAR */
    .topbar {
        padding: 18px 0;
        border-bottom: 1px solid #e2e8f0;
        background: #ffffff;
    }

    .brand {
        font-weight: 800;
        letter-spacing: -0.5px;
        font-size: 1.2rem;
    }

    /* HERO */
    .hero {
        padding: 110px 20px 80px;
        text-align: center;
        background: linear-gradient(180deg, #ffffff 0%, #f1f5f9 100%);
    }

        .hero h1 {
            font-size: 3.2rem;
            font-weight: 800;
            letter-spacing: -1px;
        }

        .hero p {
            max-width: 750px;
            margin: 18px auto 0;
            font-size: 1.15rem;
            color: #475569;
            line-height: 1.7;
        }

    .pill {
        display: inline-block;
        padding: 6px 14px;
        border-radius: 999px;
        background: #e0f2fe;
        color: #0369a1;
        font-weight: 600;
        font-size: 0.8rem;
        margin-bottom: 16px;
    }

    /* SECTION */
    .section {
        padding: 80px 20px;
    }

    .cardx {
        background: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 28px;
        height: 100%;
        transition: 0.25s ease;
        box-shadow: 0 4px 12px rgba(15, 23, 42, 0.05);
    }

        .cardx:hover {
            transform: translateY(-6px);
            box-shadow: 0 14px 30px rgba(15, 23, 42, 0.10);
        }

    .title {
        font-weight: 700;
        font-size: 1.2rem;
        margin-bottom: 10px;
    }

    .text {
        color: #64748b;
        font-size: 0.95rem;
        line-height: 1.6;
    }

    /* FOOTER */
    footer {
        padding: 40px;
        text-align: center;
        color: #64748b;
        border-top: 1px solid #e2e8f0;
        background: #fff;
    }
</style>

<!-- TOPBAR -->
<div class="topbar">
    <div class="container d-flex justify-content-between align-items-center">
        <div class="brand">Lingua System</div>
    </div>
</div>

<!-- HERO -->
<div class="hero">
    <div class="container">
        <span class="pill">ASP.NET MVC · C# · Web Application</span>
        <h1>Lingua System</h1>
        <p>
            Plataforma web desarrollada con ASP.NET MVC y C#, diseñada para ofrecer
            una estructura sólida, escalable y orientada a buenas prácticas de ingeniería de software.
        </p>
    </div>
</div>

<!-- FEATURES -->
<div class="container section">
    <div class="row g-4">

        <div class="col-md-4">
            <div class="cardx">
                <div class="title">Arquitectura profesional</div>
                <div class="text">
                    Separación de responsabilidades utilizando el patrón MVC para mantener un código limpio y escalable.
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="cardx">
                <div class="title">Backend en C#</div>
                <div class="text">
                    Lógica de negocio desarrollada en C#, optimizada para rendimiento y mantenibilidad.
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="cardx">
                <div class="title">Interfaz moderna</div>
                <div class="text">
                    Diseño limpio con enfoque profesional, pensado para una experiencia de usuario clara y eficiente.
                </div>
            </div>
        </div>

    </div>
</div>

<!-- FOOTER -->
<footer>
    © 2026 Lingua System · All rights reserved
</footer>